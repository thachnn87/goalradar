# ── Primary data provider — football-data.org ────────────────────────────────
# Get your free API key at https://www.football-data.org/
FOOTBALL_API_KEY=your_football_data_api_key

# ── Secondary data provider — api-football.com (failover) ────────────────────
# Get your free key at https://dashboard.api-football.com/profile?access
# 100 requests/day on the free tier. Used automatically when football-data.org
# returns 403, 429, 5xx or times out.
API_FOOTBALL_KEY=your_api_football_key

# ── OneSignal Web Push ────────────────────────────────────────────────────────
# Get your App ID from https://app.onesignal.com — free tier: unlimited web pushes.
# When set, the OneSignal SDK loads on every page and the "Enable Match Alerts"
# button becomes active on /world-cup-2026 and /match/[id] pages.
# Opt-in events are tracked via Vercel KV at push:grants:total.
NEXT_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id

# ── Static World Cup dataset ─────────────────────────────────────────────────
# Set to "static" to serve all WC pre-tournament pages from src/data/worldcup/
# instead of calling external APIs. Live scores, results and standings continue
# to use APIs even when this is set. Useful during provider outages or before
# the tournament begins.
# WORLD_CUP_DATA_SOURCE=static

# ── Debug endpoint token ──────────────────────────────────────────────────────
# Protects GET /api/debug/providers in production. Any random secret string.
DEBUG_TOKEN=your_random_debug_token

# ── Vercel KV (Redis) ─────────────────────────────────────────────────────────
# Set automatically by Vercel KV integration
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Vercel Postgres ───────────────────────────────────────────────────────────
# Set automatically by Vercel Postgres integration
# Run the one-time migration after adding the integration:
#   curl -H "Authorization: Bearer $CRON_SECRET" https://goalradar.org/api/newsletter/migrate
POSTGRES_URL=

# ── Resend (transactional email) ──────────────────────────────────────────────
# https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_your_resend_api_key

# Verified sender address (must match a domain you've verified in Resend)
NEWSLETTER_FROM_EMAIL=newsletter@goalradar.org

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://goalradar.org

# ── Cron / admin secret ───────────────────────────────────────────────────────
# Used to protect /api/newsletter/migrate and cron refresh routes
CRON_SECRET=your_random_secret_here

# ── AdSense (optional) ────────────────────────────────────────────────────────
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx
